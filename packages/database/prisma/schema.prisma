generator client {
  provider = "prisma-client"
  output   = "../generated/client"
  runtime  = "nodejs"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────
// Identity & access
// ─────────────────────────────────────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  avatarUrl    String?  @map("avatar_url")
  role         UserRole @default(USER)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  refreshTokens   RefreshToken[]
  orgMemberships  OrgMember[]
  comments        Comment[]
  aiConversations AiConversation[]
  auditLogs       AuditLog[]
  docVersions     DocVersion[]

  @@map("users")
}

model RefreshToken {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  tokenHash  String    @unique @map("token_hash")
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members      OrgMember[]
  projects     Project[]
  skills       Skill[]
  agents       Agent[]
  workflows    Workflow[]
  aiProviders  AiProvider[]
  conversations AiConversation[]
  apiKeys      ApiKey[]
  auditLogs    AuditLog[]

  @@map("organizations")
}

enum OrgRole {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}

model OrgMember {
  id        String   @id @default(cuid())
  orgId     String   @map("org_id")
  userId    String   @map("user_id")
  role      OrgRole  @default(VIEWER)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@map("org_members")
}

// ─────────────────────────────────────────────────────────────────────────
// Projects & files
// ─────────────────────────────────────────────────────────────────────────

model Project {
  id          String   @id @default(cuid())
  orgId       String   @map("org_id")
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  files        File[]

  @@index([orgId])
  @@map("projects")
}

/// A single design document.
model File {
  id           String    @id @default(cuid())
  projectId    String    @map("project_id")
  name         String
  thumbnailUrl String?   @map("thumbnail_url")
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  project     Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  docUpdates  DocUpdate[]
  docSnapshots DocSnapshot[]
  docVersions DocVersion[]
  components  Component[]
  comments    Comment[]

  @@index([projectId])
  @@map("files")
}

// ─────────────────────────────────────────────────────────────────────────
// Yjs document log
// ─────────────────────────────────────────────────────────────────────────

/// Append-only Yjs update log for a file's CRDT document.
model DocUpdate {
  id        String   @id @default(cuid())
  fileId    String   @map("file_id")
  seq       Int
  update    Bytes
  createdAt DateTime @default(now()) @map("created_at")

  file File @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@unique([fileId, seq])
  @@map("doc_updates")
}

/// A user-named checkpoint. Non-destructive by construction: it stores NO
/// document state, only a label pointing at the log sequence (`seq`) it
/// captures. The state as of that seq is reconstructed from snapshots + the
/// append-only update log (creating a version also writes a correctly-labelled
/// DocSnapshot at `seq`, so the checkpoint stays reconstructable even after the
/// live log is compacted — snapshots are never deleted by compaction).
model DocVersion {
  id        String   @id @default(cuid())
  fileId    String   @map("file_id")
  name      String
  seq       Int
  authorId  String   @map("author_id")
  createdAt DateTime @default(now()) @map("created_at")

  file   File @relation(fields: [fileId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([fileId, createdAt])
  @@map("doc_versions")
}

/// Compacted Yjs state, used to bound replay cost.
model DocSnapshot {
  id        String   @id @default(cuid())
  fileId    String   @map("file_id")
  upToSeq   Int      @map("up_to_seq")
  state     Bytes
  createdAt DateTime @default(now()) @map("created_at")

  file File @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([fileId])
  @@map("doc_snapshots")
}

// ─────────────────────────────────────────────────────────────────────────
// Component registry
// ─────────────────────────────────────────────────────────────────────────

/// Registry of published components, keyed by node inside a document.
model Component {
  id          String   @id @default(cuid())
  fileId      String   @map("file_id")
  nodeId      String   @map("node_id")
  name        String
  description String?
  metadata    Json
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  file             File                  @relation(fields: [fileId], references: [id], onDelete: Cascade)
  embedding        ComponentEmbedding?
  attachments      ComponentAttachment[]
  generatedCode    GeneratedCode[]

  @@unique([fileId, nodeId])
  @@map("components")
}

/// Raw-SQL managed pgvector embedding for semantic component search.
model ComponentEmbedding {
  id          String                 @id @default(cuid())
  componentId String                 @unique @map("component_id")
  embedding   Unsupported("vector(1536)")?
  model       String
  createdAt   DateTime               @default(now()) @map("created_at")
  updatedAt   DateTime               @updatedAt @map("updated_at")

  component Component @relation(fields: [componentId], references: [id], onDelete: Cascade)

  @@map("component_embeddings")
}

// ─────────────────────────────────────────────────────────────────────────
// AI: skills, agents, workflows
// ─────────────────────────────────────────────────────────────────────────

model Skill {
  id               String   @id @default(cuid())
  orgId            String?  @map("org_id")
  name             String
  description      String
  systemPrompt     String   @map("system_prompt")
  outputSchema     Json?    @map("output_schema")
  examples         Json?
  toolPermissions  Json?    @map("tool_permissions")
  builtIn          Boolean  @default(false) @map("built_in")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  organization Organization?         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  agents       Agent[]               @relation("AgentSkills")
  attachments  ComponentAttachment[]

  @@index([orgId])
  @@map("skills")
}

enum AiProviderKind {
  OPENAI
  ANTHROPIC
  GOOGLE
  LOCAL
}

model Agent {
  id          String         @id @default(cuid())
  orgId       String?        @map("org_id")
  name        String
  description String
  provider    AiProviderKind
  model       String
  config      Json?
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  organization    Organization?         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  skills          Skill[]               @relation("AgentSkills")
  attachments     ComponentAttachment[]
  conversations   AiConversation[]

  @@index([orgId])
  @@map("agents")
}

model Workflow {
  id          String   @id @default(cuid())
  orgId       String?  @map("org_id")
  name        String
  description String
  /// Ordered steps: [{ agentId, instructions? }]
  definition  Json
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  organization Organization?         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  attachments  ComponentAttachment[]

  @@index([orgId])
  @@map("workflows")
}

/// Links a component to a skill, agent, and/or workflow. At least one of
/// skillId/agentId/workflowId must be set — enforced in the repository layer.
model ComponentAttachment {
  id          String   @id @default(cuid())
  componentId String   @map("component_id")
  skillId     String?  @map("skill_id")
  agentId     String?  @map("agent_id")
  workflowId  String?  @map("workflow_id")
  prompts     Json?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  component Component @relation(fields: [componentId], references: [id], onDelete: Cascade)
  skill     Skill?    @relation(fields: [skillId], references: [id], onDelete: SetNull)
  agent     Agent?    @relation(fields: [agentId], references: [id], onDelete: SetNull)
  workflow  Workflow? @relation(fields: [workflowId], references: [id], onDelete: SetNull)

  @@index([componentId])
  @@map("component_attachments")
}

enum CodeFramework {
  REACT
  NEXTJS
  VUE
  ANGULAR
  FLUTTER
  SWIFTUI
  COMPOSE
  HTML_CSS
  HTML_TAILWIND
}

model GeneratedCode {
  id          String        @id @default(cuid())
  componentId String        @map("component_id")
  framework   CodeFramework
  code        String
  version     Int
  hash        String
  createdAt   DateTime      @default(now()) @map("created_at")

  component Component @relation(fields: [componentId], references: [id], onDelete: Cascade)

  @@unique([componentId, framework, version])
  @@map("generated_code")
}

// ─────────────────────────────────────────────────────────────────────────
// AI providers & conversations
// ─────────────────────────────────────────────────────────────────────────

model AiProvider {
  id           String         @id @default(cuid())
  orgId        String         @map("org_id")
  provider     AiProviderKind
  encryptedKey String         @map("encrypted_key")
  baseUrl      String?        @map("base_url")
  enabled      Boolean        @default(true)
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, provider])
  @@map("ai_providers")
}

model AiConversation {
  id        String   @id @default(cuid())
  orgId     String   @map("org_id")
  userId    String?  @map("user_id")
  agentId   String?  @map("agent_id")
  title     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  agent        Agent?       @relation(fields: [agentId], references: [id], onDelete: SetNull)
  messages     AiMessage[]

  @@index([orgId])
  @@map("ai_conversations")
}

enum MessageRole {
  SYSTEM
  USER
  ASSISTANT
  TOOL
}

model AiMessage {
  id             String      @id @default(cuid())
  conversationId String      @map("conversation_id")
  role           MessageRole
  content        Json
  tokenCount     Int?        @map("token_count")
  createdAt      DateTime    @default(now()) @map("created_at")

  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("ai_messages")
}

// ─────────────────────────────────────────────────────────────────────────
// Collaboration
// ─────────────────────────────────────────────────────────────────────────

model Comment {
  id         String    @id @default(cuid())
  fileId     String    @map("file_id")
  nodeId     String?   @map("node_id")
  authorId   String    @map("author_id")
  body       String
  anchorX    Float?    @map("anchor_x")
  anchorY    Float?    @map("anchor_y")
  resolvedAt DateTime? @map("resolved_at")
  parentId   String?   @map("parent_id")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  file    File      @relation(fields: [fileId], references: [id], onDelete: Cascade)
  author  User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("CommentThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies Comment[] @relation("CommentThread")

  @@index([fileId])
  @@index([parentId])
  @@map("comments")
}

// ─────────────────────────────────────────────────────────────────────────
// API keys & audit
// ─────────────────────────────────────────────────────────────────────────

model ApiKey {
  id         String    @id @default(cuid())
  orgId      String    @map("org_id")
  name       String
  keyHash    String    @unique @map("key_hash")
  scopes     String[]
  lastUsedAt DateTime? @map("last_used_at")
  expiresAt  DateTime? @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@map("api_keys")
}

model AuditLog {
  id         String   @id @default(cuid())
  orgId      String?  @map("org_id")
  userId     String?  @map("user_id")
  action     String
  targetType String?  @map("target_type")
  targetId   String?  @map("target_id")
  detail     Json?
  createdAt  DateTime @default(now()) @map("created_at")

  organization Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([orgId, createdAt])
  @@map("audit_logs")
}
