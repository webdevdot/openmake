# --- Postgres (primary database) ---
POSTGRES_USER=openmake
POSTGRES_PASSWORD=change-me
POSTGRES_DB=openmake
POSTGRES_PORT=5432
DATABASE_URL=postgresql://openmake:change-me@localhost:5432/openmake

# --- Redis (presence / pubsub / rate-limit state) ---
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# --- MinIO / S3 (large binary assets) ---
MINIO_ROOT_USER=openmake
MINIO_ROOT_PASSWORD=change-me-too
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=openmake
S3_SECRET_KEY=change-me-too
S3_BUCKET=openmake-assets

# --- Server ---
SERVER_PORT=8080
# openssl rand -hex 32
JWT_SECRET=
# openssl rand -hex 32 — encrypts stored AI provider API keys (AES-256-GCM)
MASTER_ENCRYPTION_KEY=
# comma-separated origins allowed by CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Web ---
WEB_PORT=3000
VITE_API_URL=http://localhost:8080
