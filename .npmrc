# npm supply-chain protection (4-layer model) — see docs/keys/tasks/2026-07-05-webcloudkey-design-platform.md
# Layer 1: cooldown — no packages published in the last 7 days
min-release-age=7
# Layer 2: block ALL install/postinstall scripts (the main attack vector)
ignore-scripts=true
# Layer 3: strict audit — fail on high+ severity
audit-level=high
# Layer 4: exact pins — no silent ^/~ upgrades
save-exact=true

# pnpm: strict peer resolution off to keep monorepo installs sane
strict-peer-dependencies=false
